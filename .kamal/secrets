# Secrets for `bin/kamal deploy` / `setup`. Pulled from the macOS
# login keychain so nothing sensitive ever lands on disk or in git.
#
# Manual one-time setup on a new workstation (each prompts for the
# value; paste and hit return):
#   security add-generic-password -a "$USER" -s super-barato-ghcr-pat              -w
#   security add-generic-password -a "$USER" -s super-barato-secret-key-base       -w
#   security add-generic-password -a "$USER" -s super-barato-sendgrid-api-key      -w
#   security add-generic-password -a "$USER" -s super-barato-r2-account-id         -w
#   security add-generic-password -a "$USER" -s super-barato-r2-access-key-id      -w
#   security add-generic-password -a "$USER" -s super-barato-r2-secret-access-key  -w
#
# The admin session salts are auto-generated and persisted to the
# keychain on first run (see `keychain_or_generate` below). You
# never need to know or rotate them by hand.
#
# R2_BUCKET and R2_PUBLIC_BASE are NOT secrets — they're plain
# config values declared in `config/deploy.yml`'s `env.clear:`.
#
# The first `kamal` run will pop a keychain auth prompt per entry —
# tick "Always Allow" to avoid future prompts.

# Read a keychain entry; if missing, generate a fresh 32-byte hex
# value, store it, and read it back. Idempotent: subsequent calls
# are pure reads.
keychain_or_generate() {
  local label=$1
  if ! security find-generic-password -a "$USER" -s "$label" -w >/dev/null 2>&1; then
    security add-generic-password -a "$USER" -s "$label" -w "$(openssl rand -hex 32)" -U >/dev/null
  fi
  security find-generic-password -a "$USER" -s "$label" -w
}

export KAMAL_REGISTRY_PASSWORD=$(security find-generic-password -a "$USER" -s super-barato-ghcr-pat -w)
export SECRET_KEY_BASE=$(security find-generic-password -a "$USER" -s super-barato-secret-key-base -w)
export SENDGRID_API_KEY=$(security find-generic-password -a "$USER" -s super-barato-sendgrid-api-key -w)

# Cloudflare R2 — only the credentials are secret; bucket name and
# public base URL live in `config/deploy.yml`'s `env.clear:`.
export R2_ACCOUNT_ID=$(security find-generic-password -a "$USER" -s super-barato-r2-account-id -w)
export R2_ACCESS_KEY_ID=$(security find-generic-password -a "$USER" -s super-barato-r2-access-key-id -w)
export R2_SECRET_ACCESS_KEY=$(security find-generic-password -a "$USER" -s super-barato-r2-secret-access-key -w)

# Admin session cookie salts — auto-generated on first deploy,
# persisted to the keychain, never rotated unless you delete the
# entry. Independent from SECRET_KEY_BASE so the admin and app-user
# cookie threat surfaces stay decoupled.
export ADMIN_SIGNING_SALT=$(keychain_or_generate super-barato-admin-signing-salt)
export ADMIN_ENCRYPTION_SALT=$(keychain_or_generate super-barato-admin-encryption-salt)

# Tottus's prod IP is banned at Cloudflare's edge. We route those
# requests through a Tailscale-connected iMac at home running
# tinyproxy on the Tailscale interface, giving Tottus a Chilean
# residential egress. The IP is stable inside the tailnet (set in
# the Tailscale admin console), so hardcoding here is fine; if it
# ever changes, regenerate the deploy secret.
export TOTTUS_PROXY_URL=http://100.89.170.81:8888
