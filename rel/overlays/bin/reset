#!/bin/sh
# Production equivalent of `mix ecto.reset` — drops the SQLite file,
# re-runs migrations, evaluates priv/repo/seeds.exs. Mirrors the
# `mix.exs` aliases:
#
#     "ecto.reset": ["ecto.drop", "ecto.setup"]
#     "ecto.setup": ["ecto.create", "ecto.migrate", "run priv/repo/seeds.exs"]
#
# Stop the app first so no BEAM has an open SQLite handle on the
# file we're about to delete:
#
#     kamal app stop
#     kamal reset
#     kamal app start
set -eu

cd -P -- "$(dirname -- "$0")"

DB="${DATABASE_PATH:-/data/db/super_barato.db}"

echo ">> dropping $DB (and WAL/shm sidecars)"
rm -f "$DB" "$DB-wal" "$DB-shm"

echo ">> migrating"
./super_barato eval 'SuperBarato.Release.migrate()'

echo ">> seeding"
# `bin/super_barato eval` only loads code — the supervision tree (and
# therefore SuperBarato.Repo) isn't started. Wrap the seed eval in
# Ecto.Migrator.with_repo/2 so the repo's started for the duration
# (same pattern Release.migrate/0 uses) and stopped cleanly after.
./super_barato eval '{:ok, _, _} = Ecto.Migrator.with_repo(SuperBarato.Repo, fn _ -> Code.eval_file(Application.app_dir(:super_barato, "priv/repo/seeds.exs")) end)'

echo ">> done"
