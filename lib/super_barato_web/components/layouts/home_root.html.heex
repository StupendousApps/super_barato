<!DOCTYPE html>
<html lang="es-CL" class="home">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="SuperBarato.cl">
      {assigns[:page_title]}
    </.live_title>

    <%!-- Sidebar collapse state. Read synchronously from localStorage
         and applied to <html> before any CSS computes, so the rails
         render in their saved state on the very first paint (no
         expand-then-collapse flash on reload). The Rails JS hook
         keeps these attributes in sync after mount. --%>
    <script>
      (function () {
        try {
          var raw = window.localStorage.getItem("super_barato.rails.collapsed");
          var s = raw ? JSON.parse(raw) : {};
          var d = document.documentElement;
          d.dataset.railLeft  = s.left  ? "collapsed" : "expanded";
          d.dataset.railRight = s.right ? "collapsed" : "expanded";
        } catch (_e) {}
      })();
    </script>

    <link rel="stylesheet" href={~p"/assets/css/app/reset.css"} />
    <link rel="stylesheet" href={~p"/assets/css/app/variables.css"} />
    <link rel="stylesheet" href={~p"/assets/css/app/layout.css"} />
    <link rel="stylesheet" href={~p"/assets/css/app/rails.css"} />
    <link rel="stylesheet" href={~p"/assets/css/app/categories.css"} />
    <link rel="stylesheet" href={~p"/assets/css/app/search.css"} />
    <link rel="stylesheet" href={~p"/assets/css/app/results.css"} />
    <link rel="stylesheet" href={~p"/assets/css/app/card.css"} />
    <link rel="stylesheet" href={~p"/assets/css/app/cart.css"} />
    <link rel="stylesheet" href={~p"/assets/css/app/modal.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script
      :if={Application.get_env(:super_barato, :analytics_enabled, false)}
      defer
      src="https://stats.superbarato.cl/script.js"
      data-website-id="2ad746e8-af46-415e-925f-9feaa9f5069e"
    >
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
